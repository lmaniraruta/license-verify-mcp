  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "apify": "^3.7.2",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "apify-cli": "^1.6.2",
    "tsx": "^4.0.0"
