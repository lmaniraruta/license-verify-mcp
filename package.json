    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "start": "node dist/actor.js",
    "start:mcp": "node dist/index.js",
    "start:actor": "node dist/actor.js",
    "smoke": "tsx scripts/smoke.ts"
  },
  "keywords": [
    "mcp",
